# ---------------------------------------------------------------------------
# PaperScout AI — Environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paperscout?schema=public"

# ---------------------------------------------------------------------------
# AI provider (OPTIONAL)
# If AI_API_KEY is empty or unset, the app automatically uses the deterministic
# rule-based fallback for recommendations. No key is required to run the MVP.
# ---------------------------------------------------------------------------
AI_API_KEY=""
AI_API_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# Timeout (ms) for AI provider requests before falling back to rule-based.
AI_TIMEOUT_MS="20000"
