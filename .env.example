# ---------------------------------------------------------------------------
# PaperScout AI — Environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# DATABASE (flexible: local zero-install  OR  real PostgreSQL)
#
# The app picks the driver automatically from the URL scheme:
#   - "pglite://<dir>"   -> embedded PGlite. Zero install, persists to a local
#                           folder, auto-creates schema + seeds on first start.
#                           Best for local development.
#   - "postgresql://..." -> real PostgreSQL via the node-postgres adapter.
#                           Use for online/production (e.g. Neon, Supabase).
#
# Local default (recommended for first run — no Postgres needed):
DATABASE_URL="pglite://.pglite"
#
# Online / production example (Neon — note the required sslmode):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# After setting a postgresql:// URL, create the schema once:
#   npm run db:push     # syncs schema.prisma to the database
#   npm run db:seed     # optional: sample conferences/special-issues/papers
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# AI provider (OPTIONAL — OpenAI-compatible)
#
# If neither an API key nor a custom base URL is set, the app uses the
# deterministic rule-based fallback. No AI is required to run the MVP.
#
# Option A — Hosted OpenAI (or compatible) with a key:
#   AI_API_KEY="sk-..."
#   AI_API_BASE_URL="https://api.openai.com/v1"
#   AI_MODEL="gpt-4o-mini"
#
# Option B — Self-hosted small model via Ollama (no key needed):
#   1. Install Ollama (https://ollama.com) and run:  ollama pull llama3.2
#   2. For semantic matching, also:  ollama pull nomic-embed-text
#   3. Ollama serves an OpenAI-compatible API at http://localhost:11434/v1
#   AI_API_KEY=""
#   AI_API_BASE_URL="http://localhost:11434/v1"
#   AI_MODEL="llama3.2"
#   AI_EMBED_MODEL="nomic-embed-text"
#
# Option C — LM Studio local server:
#   AI_API_BASE_URL="http://localhost:1234/v1"
#   AI_MODEL="<the model id loaded in LM Studio>"
# ---------------------------------------------------------------------------
AI_API_KEY=""
AI_API_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# Embedding model for semantic journal matching (optional). Leave empty to use
# deterministic keyword matching. With Ollama: "nomic-embed-text".
AI_EMBED_MODEL=""

# Timeout (ms) for AI requests before falling back to rule-based. Local models
# on CPU can be slow on the first (cold) call, so keep this generous when using
# Ollama/LM Studio (e.g. 120000). Hosted APIs can use a smaller value.
AI_TIMEOUT_MS="120000"
AI_EMBED_TIMEOUT_MS="60000"

# ---------------------------------------------------------------------------
# OpenAlex (live journal/paper data source — free, no API key required)
# Providing a contact email uses OpenAlex's faster "polite pool".
# ---------------------------------------------------------------------------
OPENALEX_MAILTO="you@example.org"
OPENALEX_TIMEOUT_MS="12000"
